# HTTP server port
PORT=8080

# Upstream Perplexity WebSocket endpoint
PERPLEXITY_WS_URL=

# WebSocket headers — needed to look like a real browser
ORIGIN=
USER_AGENT=

# Timeouts
WS_DIAL_TIMEOUT=10s
REQUEST_TIMEOUT=5s

# Per-request retry on transient failures
MAX_RETRIES=2

# Background reconnect when the socket drops
RECONNECT_DELAY=2s
MAX_RECONNECT_ATTEMPTS=5

# Logging: debug | info | warn | error
LOG_LEVEL=info
